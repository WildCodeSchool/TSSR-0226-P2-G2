#Requires -RunAsAdministrator
# =============================================================================
#  SCRIPT D'ADMINISTRATION — WINDOWS SERVER
#  Emplacement sur le serveur : C:\AdminScripts\admin_windows.ps1
#  Permissions                : Accessible uniquement par Administrateurs
#                               (Set-Acl appliqué au démarrage)
#
#  Architecture :
#    → Ce script tourne sur le WINDOWS SERVER
#    → Il se connecte au client WINDOWS 11 via WinRM (Invoke-Command)
#    → Les commandes s'exécutent sur le CLIENT, résultat affiché sur le serveur
#    → Seul le groupe Administrateurs peut lire/lancer ce script
# =============================================================================

$ErrorActionPreference = "Continue"
$LogFile    = "C:\AdminScripts\logs\admin_windows.log"
$ScriptPath = $MyInvocation.MyCommand.Path

# -----------------------------------------------------------------------------
# SÉCURISATION DU SCRIPT AU DÉMARRAGE
# Restreint la lecture du script aux Administrateurs uniquement
# -----------------------------------------------------------------------------
function Securiser-Fichier {
    param([string]$Chemin)
    try {
        $acl = Get-Acl $Chemin

        # Supprimer l'héritage et toutes les permissions existantes
        $acl.SetAccessRuleProtection($true, $false)
        $acl.Access | ForEach-Object { $acl.RemoveAccessRule($_) | Out-Null }

        # Donner accès complet uniquement à SYSTEM et Administrateurs
        $regles = @(
            [System.Security.AccessControl.FileSystemAccessRule]::new(
                "SYSTEM", "FullControl", "Allow"),
            [System.Security.AccessControl.FileSystemAccessRule]::new(
                "Administrators", "FullControl", "Allow")
        )
        foreach ($regle in $regles) { $acl.AddAccessRule($regle) }

        Set-Acl -Path $Chemin -AclObject $acl
    } catch {
        # Permissions déjà correctes ou dossier réseau — on continue
    }
}

# Sécuriser le script et son dossier au démarrage
if ($ScriptPath) {
    Securiser-Fichier $ScriptPath
    Securiser-Fichier (Split-Path $ScriptPath)
}

# Créer le dossier de logs avec permissions restrictives
if (-not (Test-Path (Split-Path $LogFile))) {
    New-Item -ItemType Directory -Path (Split-Path $LogFile) -Force | Out-Null
    Securiser-Fichier (Split-Path $LogFile)
}

# -----------------------------------------------------------------------------
# UTILITAIRES
# -----------------------------------------------------------------------------

function Ecrire-Log {
    param([string]$Niveau, [string]$Message)
    $ligne = "[$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')] [$Niveau] [$env:USERNAME] $Message"
    try {
        Add-Content -Path $LogFile -Value $ligne -ErrorAction Stop
        # Restreindre le log à Administrateurs
        Securiser-Fichier $LogFile
    } catch {}
}

function Afficher-Ok     { param($m) Write-Host "[OK] $m"      -ForegroundColor Green }
function Afficher-Erreur { param($m) Write-Host "[ERREUR] $m"  -ForegroundColor Red }
function Afficher-Info   { param($m) Write-Host "[INFO] $m"    -ForegroundColor Cyan }

function Afficher-Titre {
    param($m)
    Clear-Host
    Write-Host ""
    Write-Host "╔══════════════════════════════════════════════════════╗" -ForegroundColor Blue
    Write-Host ("║  {0,-52}║" -f $m)                                       -ForegroundColor Blue
    Write-Host "╚══════════════════════════════════════════════════════╝" -ForegroundColor Blue
    Write-Host ""
}

function Pause-Menu {
    Write-Host "`nAppuie sur [Entrée] pour continuer..."
    $null = Read-Host
}

# Vérifie que WinRM fonctionne vers la machine cible
function Verifier-WinRM {
    param([string]$Machine)
    Afficher-Info "Test WinRM vers $Machine..."
    try {
        $null = Invoke-Command -ComputerName $Machine `
                               -ScriptBlock { $env:COMPUTERNAME } `
                               -ErrorAction Stop
        Afficher-Ok "WinRM OK vers $Machine"
        Ecrire-Log "INFO" "WinRM OK → $Machine"
        return $true
    } catch {
        Afficher-Erreur "Impossible de joindre $Machine via WinRM."
        Afficher-Info  "Sur le client Windows 11, exécute en admin :"
        Afficher-Info  "  Enable-PSRemoting -Force"
        Afficher-Info  "  Set-Item WSMan:\localhost\Client\TrustedHosts -Value '$Machine'"
        Ecrire-Log "ERREUR" "WinRM échoué → $Machine | $_"
        return $false
    }
}

# Exécute un bloc de commandes sur le CLIENT via WinRM
# Tout s'exécute sur le client — seul le résultat est affiché ici
function Executer-Sur-Client {
    param(
        [string]$Machine,
        [scriptblock]$Bloc,
        [string]$Description,
        [object[]]$Args = @()
    )
    Write-Host ""
    Afficher-Info "→ Exécution sur le client [$Machine] : $Description"
    Write-Host "──────────────────────────────────────────────────" -ForegroundColor DarkGray
    Ecrire-Log "ACTION" "[$Machine] $Description"

    try {
        if ($Args.Count -gt 0) {
            Invoke-Command -ComputerName $Machine `
                           -ScriptBlock $Bloc `
                           -ArgumentList $Args `
                           -ErrorAction Stop
        } else {
            Invoke-Command -ComputerName $Machine `
                           -ScriptBlock $Bloc `
                           -ErrorAction Stop
        }
        Write-Host "──────────────────────────────────────────────────" -ForegroundColor DarkGray
        Afficher-Ok "Succès."
        Ecrire-Log "OK" "[$Machine] $Description → succès"
    } catch {
        Write-Host "──────────────────────────────────────────────────" -ForegroundColor DarkGray
        Afficher-Erreur "Erreur : $_"
        Ecrire-Log "ERREUR" "[$Machine] $Description → $_"
    }
}

function Choisir-Machine {
    Write-Host ""
    Write-Host "IP ou nom d'hôte du client Windows 11 : " -ForegroundColor Yellow -NoNewline
    $m = Read-Host
    if ([string]::IsNullOrWhiteSpace($m)) {
        Afficher-Erreur "Aucune machine saisie."
        return $null
    }
    if (-not (Verifier-WinRM $m)) { return $null }
    return $m
}

function Saisir-Utilisateur {
    Write-Host "Nom d'utilisateur : " -ForegroundColor Yellow -NoNewline
    $u = Read-Host
    if ([string]::IsNullOrWhiteSpace($u)) { Afficher-Erreur "Nom vide."; return $null }
    return $u
}

# =============================================================================
# MODULE 1 — GESTION DES UTILISATEURS (exécuté sur le CLIENT)
# =============================================================================

function Creer-Utilisateur {
    param([string]$Machine)
    $nom = Saisir-Utilisateur; if (-not $nom) { return }
    Write-Host "Mot de passe : " -ForegroundColor Yellow -NoNewline
    $mdp = Read-Host -AsSecureString

    Executer-Sur-Client -Machine $Machine -Description "Création du compte $nom" -Args @($nom, $mdp) -Bloc {
        param($n, $p)
        New-LocalUser -Name $n -Password $p -Description "Créé par Windows Server" -ErrorAction Stop
        Write-Host "Compte '$n' créé sur le client."
    }
}

function Changer-MotDePasse {
    param([string]$Machine)
    $nom = Saisir-Utilisateur; if (-not $nom) { return }
    Write-Host "Nouveau mot de passe : " -ForegroundColor Yellow -NoNewline
    $mdp = Read-Host -AsSecureString

    Executer-Sur-Client -Machine $Machine -Description "Changement MDP de $nom" -Args @($nom, $mdp) -Bloc {
        param($n, $p)
        Set-LocalUser -Name $n -Password $p -ErrorAction Stop
        Write-Host "Mot de passe de '$n' modifié sur le client."
    }
}

function Supprimer-Utilisateur {
    param([string]$Machine)
    $nom = Saisir-Utilisateur; if (-not $nom) { return }
    Write-Host "Confirmer suppression de '$nom' ? (oui/non) : " -ForegroundColor Red -NoNewline
    if ((Read-Host) -eq "oui") {
        Executer-Sur-Client -Machine $Machine -Description "Suppression du compte $nom" -Args @($nom) -Bloc {
            param($n)
            Remove-LocalUser -Name $n -ErrorAction Stop
            Write-Host "Compte '$n' supprimé sur le client."
        }
    } else { Afficher-Info "Annulé." }
}

function Desactiver-Utilisateur {
    param([string]$Machine)
    $nom = Saisir-Utilisateur; if (-not $nom) { return }

    Executer-Sur-Client -Machine $Machine -Description "Désactivation du compte $nom" -Args @($nom) -Bloc {
        param($n)
        Disable-LocalUser -Name $n -ErrorAction Stop
        Write-Host "Compte '$n' désactivé sur le client."
    }
}

function Ajouter-GroupeAdmin {
    param([string]$Machine)
    $nom = Saisir-Utilisateur; if (-not $nom) { return }

    Executer-Sur-Client -Machine $Machine -Description "Ajout de $nom aux Administrateurs" -Args @($nom) -Bloc {
        param($n)
        Add-LocalGroupMember -Group "Administrators" -Member $n -ErrorAction Stop
        Write-Host "'$n' ajouté au groupe Administrateurs sur le client."
    }
}

function Ajouter-Groupe {
    param([string]$Machine)
    $nom = Saisir-Utilisateur; if (-not $nom) { return }
    Write-Host "Nom du groupe : " -ForegroundColor Yellow -NoNewline
    $groupe = Read-Host

    Executer-Sur-Client -Machine $Machine -Description "Ajout de $nom au groupe $groupe" -Args @($nom, $groupe) -Bloc {
        param($n, $g)
        Add-LocalGroupMember -Group $g -Member $n -ErrorAction Stop
        Write-Host "'$n' ajouté au groupe '$g' sur le client."
    }
}

function Menu-Utilisateurs {
    param([string]$Machine)
    while ($true) {
        Afficher-Titre "UTILISATEURS — Client : $Machine"
        Write-Host "  1) Créer un compte utilisateur local"
        Write-Host "  2) Changer le mot de passe"
        Write-Host "  3) Supprimer un compte utilisateur local"
        Write-Host "  4) Désactiver un compte utilisateur local"
        Write-Host "  5) Ajouter au groupe d'administration"
        Write-Host "  6) Ajouter à un groupe"
        Write-Host "  0) Retour"
        Write-Host "`nChoix : " -ForegroundColor Yellow -NoNewline
        switch (Read-Host) {
            "1" { Creer-Utilisateur $Machine }
            "2" { Changer-MotDePasse $Machine }
            "3" { Supprimer-Utilisateur $Machine }
            "4" { Desactiver-Utilisateur $Machine }
            "5" { Ajouter-GroupeAdmin $Machine }
            "6" { Ajouter-Groupe $Machine }
            "0" { return }
            default { Afficher-Erreur "Choix invalide." }
        }
        Pause-Menu
    }
}

# =============================================================================
# MODULE 2 — ACTIONS SUR LE CLIENT
# =============================================================================

function Creer-Repertoire {
    param([string]$Machine)
    Write-Host "Chemin à créer sur le client : " -ForegroundColor Yellow -NoNewline
    $chemin = Read-Host

    Executer-Sur-Client -Machine $Machine -Description "Création de $chemin" -Args @($chemin) -Bloc {
        param($c)
        New-Item -ItemType Directory -Path $c -Force -ErrorAction Stop | Out-Null
        Get-Item $c | Select-Object FullName, CreationTime
    }
}

function Supprimer-Repertoire {
    param([string]$Machine)
    Write-Host "Chemin à supprimer sur le client : " -ForegroundColor Yellow -NoNewline
    $chemin = Read-Host
    Write-Host "Confirmer suppression de '$chemin' ? (oui/non) : " -ForegroundColor Red -NoNewline
    if ((Read-Host) -eq "oui") {
        Executer-Sur-Client -Machine $Machine -Description "Suppression de $chemin" -Args @($chemin) -Bloc {
            param($c)
            Remove-Item -Path $c -Recurse -Force -ErrorAction Stop
            Write-Host "'$c' supprimé sur le client."
        }
    } else { Afficher-Info "Annulé." }
}

function Redemarrer-Machine {
    param([string]$Machine)
    Write-Host "Redémarrer le client $Machine ? (oui/non) : " -ForegroundColor Red -NoNewline
    if ((Read-Host) -eq "oui") {
        Afficher-Info "Envoi de la commande de redémarrage..."
        Ecrire-Log "ACTION" "[$Machine] Redémarrage"
        try {
            Restart-Computer -ComputerName $Machine -Force -ErrorAction Stop
            Afficher-Ok "Commande envoyée au client."
        } catch {
            Afficher-Erreur "$_"
            Ecrire-Log "ERREUR" "[$Machine] Redémarrage → $_"
        }
    } else { Afficher-Info "Annulé." }
}

function Prise-En-Main {
    param([string]$Machine)
    Afficher-Info "Ouverture d'une session interactive sur $Machine..."
    Afficher-Info "(Tu es maintenant sur le CLIENT — tape 'Exit-PSSession' pour revenir)"
    Ecrire-Log "ACTION" "[$Machine] Prise en main interactive (Enter-PSSession)"
    try {
        Enter-PSSession -ComputerName $Machine -ErrorAction Stop
    } catch {
        Afficher-Erreur "$_"
    }
    Afficher-Ok "Session fermée — retour sur le Windows Server."
    Ecrire-Log "INFO" "[$Machine] Session interactive terminée"
}

function Activer-PareFeu {
    param([string]$Machine)
    Executer-Sur-Client -Machine $Machine -Description "Activation du pare-feu Windows" -Bloc {
        Set-NetFirewallProfile -Profile Domain,Private,Public -Enabled True -ErrorAction Stop
        Get-NetFirewallProfile | Select-Object Name, Enabled | Format-Table
    }
}

function Executer-Script-Distant {
    param([string]$Machine)
    Write-Host "Chemin du script .ps1 (sur CE serveur) : " -ForegroundColor Yellow -NoNewline
    $scriptLocal = Read-Host

    if (-not (Test-Path $scriptLocal)) {
        Afficher-Erreur "Fichier introuvable sur le serveur : $scriptLocal"
        Ecrire-Log "ERREUR" "Script serveur introuvable : $scriptLocal"
        return
    }

    # Restreindre le script sur le serveur avant envoi
    Securiser-Fichier $scriptLocal

    Afficher-Info "Transfert sécurisé du script vers $Machine..."
    try {
        $session = New-PSSession -ComputerName $Machine -ErrorAction Stop

        # Créer C:\Temp sur le client si nécessaire, avec permissions admin
        Invoke-Command -Session $session -ScriptBlock {
            if (-not (Test-Path "C:\Temp")) {
                New-Item -ItemType Directory "C:\Temp" | Out-Null
            }
            # Restreindre C:\Temp aux admins uniquement
            $acl = Get-Acl "C:\Temp"
            $acl.SetAccessRuleProtection($true, $false)
            $acl.Access | ForEach-Object { $acl.RemoveAccessRule($_) | Out-Null }
            foreach ($id in @("SYSTEM","Administrators")) {
                $acl.AddAccessRule(
                    [System.Security.AccessControl.FileSystemAccessRule]::new(
                        $id, "FullControl", "ContainerInherit,ObjectInherit", "None", "Allow"))
            }
            Set-Acl "C:\Temp" $acl
        }

        Copy-Item -Path $scriptLocal `
                  -Destination "C:\Temp\script_distant.ps1" `
                  -ToSession $session -Force -ErrorAction Stop

        Afficher-Ok "Script copié sur le client."
        Ecrire-Log "OK" "[$Machine] Script $scriptLocal copié → C:\Temp\script_distant.ps1"

        Afficher-Info "Exécution du script sur le client..."
        Invoke-Command -Session $session -ScriptBlock {
            & "C:\Temp\script_distant.ps1"
            # Nettoyage après exécution
            Remove-Item "C:\Temp\script_distant.ps1" -Force -ErrorAction SilentlyContinue
        } -ErrorAction Stop

        Afficher-Ok "Script exécuté et nettoyé sur le client."
        Ecrire-Log "OK" "[$Machine] Script exécuté et supprimé"
        Remove-PSSession $session
    } catch {
        Afficher-Erreur "Erreur : $_"
        Ecrire-Log "ERREUR" "[$Machine] Script distant → $_"
    }
}

function Menu-Actions-Client {
    param([string]$Machine)
    while ($true) {
        Afficher-Titre "ACTIONS CLIENT — $Machine"
        Write-Host "  1) Créer un répertoire"
        Write-Host "  2) Supprimer un répertoire"
        Write-Host "  3) Redémarrer la machine"
        Write-Host "  4) Prise en main à distance (CLI)"
        Write-Host "  5) Activer le pare-feu"
        Write-Host "  6) Exécuter un script sur le client"
        Write-Host "  0) Retour"
        Write-Host "`nChoix : " -ForegroundColor Yellow -NoNewline
        switch (Read-Host) {
            "1" { Creer-Repertoire $Machine }
