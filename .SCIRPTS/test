}

# =============================================================================
# MODULE 3 — RÉSEAU (lu sur le CLIENT)
# =============================================================================

function Menu-Infos-Reseau {
    param([string]$Machine)
    while ($true) {
        Afficher-Titre "INFOS RÉSEAU — Client : $Machine"
        Write-Host "  1) Ports ouverts"
        Write-Host "  2) Adresse IP, masque, passerelle"
        Write-Host "  3) Liste des interfaces"
        Write-Host "  4) Version de l'OS"
        Write-Host "  0) Retour"
        Write-Host "`nChoix : " -ForegroundColor Yellow -NoNewline
        switch (Read-Host) {
            "1" { Executer-Sur-Client $Machine { netstat -ano } "Ports ouverts sur le client" }
            "2" { Executer-Sur-Client $Machine { Get-NetIPAddress | Format-Table; Get-NetRoute -DestinationPrefix "0.0.0.0/0" | Format-Table } "IP/masque/passerelle du client" }
            "3" { Executer-Sur-Client $Machine { Get-NetAdapter | Format-Table Name, Status, MacAddress, LinkSpeed } "Interfaces réseau du client" }
            "4" { Executer-Sur-Client $Machine { Get-ComputerInfo | Select-Object OsName, OsVersion } "OS du client" }
            "0" { return }
            default { Afficher-Erreur "Choix invalide." }
        }
        Pause-Menu
    }
}

# =============================================================================
# MODULE 4 — SYSTÈME (lu sur le CLIENT)
# =============================================================================

function Menu-Infos-Systeme {
    param([string]$Machine)
    while ($true) {
        Afficher-Titre "INFOS SYSTÈME — Client : $Machine"
        Write-Host "  1) Applications / paquets installés"
        Write-Host "  2) Services en cours d'exécution"
        Write-Host "  3) Mémoire RAM totale"
        Write-Host "  4) Utilisation de la RAM"
        Write-Host "  5) Mises à jour installées"
        Write-Host "  6) Marque / modèle de la machine"
        Write-Host "  7) UAC activé (Windows)"
        Write-Host "  0) Retour"
        Write-Host "`nChoix : " -ForegroundColor Yellow -NoNewline
        switch (Read-Host) {
            "1" { Executer-Sur-Client $Machine { Get-Package | Select-Object Name, Version | Sort-Object Name | Format-Table -AutoSize } "Applications installées sur le client" }
            "2" { Executer-Sur-Client $Machine { Get-Service | Where-Object { $_.Status -eq "Running" } | Select-Object Name, DisplayName | Format-Table -AutoSize } "Services actifs sur le client" }
            "3" { Executer-Sur-Client $Machine {
                    $ram = (Get-CimInstance Win32_PhysicalMemory | Measure-Object -Property Capacity -Sum).Sum / 1GB
                    Write-Host "RAM totale sur le client : $([math]::Round($ram,2)) Go"
                } "RAM totale du client" }
            "4" { Executer-Sur-Client $Machine {
                    $os = Get-CimInstance Win32_OperatingSystem
                    $total = [math]::Round($os.TotalVisibleMemorySize/1MB, 2)
                    $libre = [math]::Round($os.FreePhysicalMemory/1MB, 2)
                    Write-Host "RAM totale : $total Go | Utilisée : $([math]::Round($total-$libre,2)) Go | Libre : $libre Go"
                } "Utilisation RAM du client" }
            "5" { Executer-Sur-Client $Machine { Get-HotFix | Sort-Object InstalledOn -Descending | Select-Object -First 10 | Format-Table HotFixID, Description, InstalledOn -AutoSize } "MAJ du client" }
            "6" { Executer-Sur-Client $Machine { Get-CimInstance Win32_ComputerSystem | Select-Object Manufacturer, Model | Format-List } "Marque/modèle du client" }
            "7" { Executer-Sur-Client $Machine {
                    $v = (Get-ItemProperty "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\System").EnableLUA
                    if ($v -eq 1) { Write-Host "UAC : ACTIVÉ" -ForegroundColor Green }
                    else          { Write-Host "UAC : DÉSACTIVÉ" -ForegroundColor Red }
                } "Statut UAC du client" }
            "0" { return }
            default { Afficher-Erreur "Choix invalide." }
        }
        Pause-Menu
    }
}

# =============================================================================
# MODULE 5 — DROITS (vérifiés sur le CLIENT)
# =============================================================================

function Menu-Infos-Utilisateur {
    param([string]$Machine)
    while ($true) {
        Afficher-Titre "DROITS UTILISATEUR — Client : $Machine"
        Write-Host "  1) Groupe d'appartenance d'un utilisateur"
        Write-Host "  2) Droits / permissions sur un fichier"
        Write-Host "  0) Retour"
        Write-Host "`nChoix : " -ForegroundColor Yellow -NoNewline
        switch (Read-Host) {
            "1" {
                $nom = Saisir-Utilisateur; if (-not $nom) { Pause-Menu; continue }
                Executer-Sur-Client -Machine $Machine -Description "Groupes de $nom sur le client" -Args @($nom) -Bloc {
                    param($n)
                    $u = Get-LocalUser -Name $n -ErrorAction Stop
                    Write-Host "Compte : $($u.Name) | Activé : $($u.Enabled)"
                    $grps = Get-LocalGroup | Where-Object {
                        (Get-LocalGroupMember $_ -ErrorAction SilentlyContinue).Name -match $n
                    }
                    Write-Host "Groupes :"; $grps | Select-Object Name | Format-Table -AutoSize
                }
            }
            "2" {
                Write-Host "Chemin du fichier sur le client : " -ForegroundColor Yellow -NoNewline
                $chemin = Read-Host
                Executer-Sur-Client -Machine $Machine -Description "Droits sur $chemin" -Args @($chemin) -Bloc {
                    param($c) Get-Acl $c | Format-List
                }
            }
            "0" { return }
            default { Afficher-Erreur "Choix invalide." }
        }
        Pause-Menu
    }
}

