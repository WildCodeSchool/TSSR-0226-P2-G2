function Menu-Logs {
    param([string]$Machine)
    $logClient = "C:\Logs\log_ext.log"
    while ($true) {
        Afficher-Titre "LOGS — Client : $Machine"
        Write-Host "  Fichier ciblé sur le client : $logClient`n" -ForegroundColor Cyan
        Write-Host "  1) Recherche par utilisateur dans log_ext.log"
        Write-Host "  2) Recherche par ordinateur dans log_ext.log"
        Write-Host "  3) Afficher les 50 dernières lignes"
        Write-Host "  0) Retour"
        Write-Host "`nChoix : " -ForegroundColor Yellow -NoNewline
        switch (Read-Host) {
            "1" {
                Write-Host "Nom de l'utilisateur : " -ForegroundColor Yellow -NoNewline
                $rech = Read-Host
                Executer-Sur-Client -Machine $Machine -Description "Recherche '$rech' dans les logs du client" -Args @($logClient, $rech) -Bloc {
                    param($f, $r)
                    if (Test-Path $f) {
                        $res = Select-String -Path $f -Pattern $r
                        if ($res) { $res } else { Write-Host "Aucun résultat pour '$r'." }
                    } else { Write-Host "Fichier introuvable sur le client : $f" -ForegroundColor Red }
                }
            }
            "2" {
                Write-Host "Nom de la machine : " -ForegroundColor Yellow -NoNewline
                $rech = Read-Host
                Executer-Sur-Client -Machine $Machine -Description "Recherche '$rech' dans les logs du client" -Args @($logClient, $rech) -Bloc {
                    param($f, $r)
                    if (Test-Path $f) {
                        $res = Select-String -Path $f -Pattern $r
                        if ($res) { $res } else { Write-Host "Aucun résultat pour '$r'." }
                    } else { Write-Host "Fichier introuvable sur le client : $f" -ForegroundColor Red }
                }
            }
            "3" {
                Executer-Sur-Client -Machine $Machine -Description "Dernières lignes du log du client" -Args @($logClient) -Bloc {
                    param($f)
                    if (Test-Path $f) { Get-Content $f -Tail 50 }
                    else { Write-Host "Fichier introuvable : $f" -ForegroundColor Red }
                }
            }
            "0" { return }
            default { Afficher-Erreur "Choix invalide." }
        }
        Pause-Menu
    }
}

# =============================================================================
# MENU PRINCIPAL
# =============================================================================

function Menu-Principal {
    Ecrire-Log "INFO" "=== Démarrage script admin Windows Server ==="

    Afficher-Titre "WINDOWS SERVER — Connexion au client Windows 11"
    $Machine = Choisir-Machine
    if (-not $Machine) {
        Afficher-Erreur "Connexion impossible. Fermeture."
        exit 1
    }

    while ($true) {
        Afficher-Titre "WINDOWS SERVER → CLIENT : $Machine"
        Write-Host "  Serveur  : " -NoNewline; Write-Host $env:COMPUTERNAME -ForegroundColor Cyan
        Write-Host "  Client   : " -NoNewline; Write-Host $Machine          -ForegroundColor Green
        Write-Host ""
        Write-Host "  1) Gestion des utilisateurs"
        Write-Host "  2) Actions sur le client"
        Write-Host "  3) Informations réseau"
        Write-Host "  4) Informations système"
        Write-Host "  5) Droits utilisateur"
        Write-Host "  6) Analyse des logs"
        Write-Host ""
        Write-Host "  c) Changer de client cible"
        Write-Host "  0) Quitter"
        Write-Host "`nChoix : " -ForegroundColor Yellow -NoNewline

        switch (Read-Host) {
            "1" { Menu-Utilisateurs $Machine }
            "2" { Menu-Actions-Client $Machine }
            "3" { Menu-Infos-Reseau $Machine }
            "4" { Menu-Infos-Systeme $Machine }
            "5" { Menu-Infos-Utilisateur $Machine }
            "6" { Menu-Logs $Machine }
            { $_ -in "c","C" } {
                Afficher-Titre "CHANGEMENT DE CLIENT"
                $nouveau = Choisir-Machine
                if ($nouveau) { $Machine = $nouveau }
            }
            "0" {
                Afficher-Info "Fermeture. À bientôt !"
                Ecrire-Log "INFO" "=== Script fermé ==="
                exit 0
            }
            default { Afficher-Erreur "Choix invalide." ; Pause-Menu }
        }
    }
}

