#!/bin/bash

# ==========================================
# Script Bash - Administration du client Ubuntu
# Exécution : serveur Debian
# Cible : client Ubuntu
# ==========================================

# VARIABLES
REMOTE_HOST="ubuntu"
CURRENT_USER="$(whoami)"
LOG_FILE="log_evt.log"
INFO_DIR="info"
TARGET_NAME="ubuntu"

# COULEURS
RED="\e[91m"
GREEN="\e[92m"
YELLOW="\e[93m"
BLUE="\e[94m"
CYAN="\e[96m"
RESET="\e[0m"

# INITIALISATION
mkdir -p "$INFO_DIR"
touch "$LOG_FILE"

# ==========================================
# FONCTIONS GENERALES
# ==========================================

log_action() {
    echo "$(date '+%Y%m%d_%H%M%S')_${CURRENT_USER}_$1" >> "$LOG_FILE"
}

pause() {
    read -p "Appuyez sur Entrée pour continuer..."
}

save_info() {
    name="$1"
    content="$2"
    date_jour="$(date '+%Y%m%d')"
    file_name="${INFO_DIR}/info_${name}_${date_jour}.txt"

    echo "$content" > "$file_name"
    echo -e "${GREEN}Informations enregistrées dans ${file_name}${RESET}"
}

ssh_cmd() {
    ssh "$REMOTE_HOST" "$1"
}

# ==========================================
# INFORMATIONS ORDINATEUR
# ==========================================

info_systeme() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "      INFORMATIONS SYSTEME"
    echo -e "==================================${RESET}"

    content="$(ssh_cmd "echo 'Nom de la machine :'; hostname; echo; echo 'Date :'; date; echo; echo 'Uptime :'; uptime -p")"
    echo "$content"
    save_info "$TARGET_NAME" "$content"
    log_action "InfoSysteme_Ubuntu"

    pause
}

info_ports_ouverts() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "          PORTS OUVERTS"
    echo -e "==================================${RESET}"

    content="$(ssh_cmd "ss -tuln")"
    echo "$content"
    save_info "$TARGET_NAME" "$content"
    log_action "PortsOuverts_Ubuntu"

    pause
}

info_reseau() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "      CONFIGURATION RESEAU"
    echo -e "==================================${RESET}"

    content="$(ssh_cmd "echo 'Adresse IP :'; hostname -I; echo; echo 'Passerelle :'; ip route | grep default")"
    echo "$content"
    save_info "$TARGET_NAME" "$content"
    log_action "InfoReseau_Ubuntu"

    pause
}

info_interfaces() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "       LISTE DES INTERFACES"
    echo -e "==================================${RESET}"

    content="$(ssh_cmd "ip -o link show | awk -F': ' '{print \$2}'")"
    echo "$content"
    save_info "$TARGET_NAME" "$content"
    log_action "Interfaces_Ubuntu"

    pause
}

info_version_os() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "         VERSION DE L'OS"
    echo -e "==================================${RESET}"

    content="$(ssh_cmd "cat /etc/os-release")"
    echo "$content"
    save_info "$TARGET_NAME" "$content"
    log_action "VersionOS_Ubuntu"

    pause
}

info_paquets() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "       PAQUETS INSTALLES"
    echo -e "==================================${RESET}"

    content="$(ssh_cmd "dpkg -l")"
    echo "$content"
    save_info "$TARGET_NAME" "$content"
    log_action "Paquets_Ubuntu"

    pause
}

info_services() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "      SERVICES EN COURS"
    echo -e "==================================${RESET}"

    content="$(ssh_cmd "systemctl list-units --type=service --state=running")"
    echo "$content"
    save_info "$TARGET_NAME" "$content"
    log_action "Services_Ubuntu"

    pause
}

info_ram_totale() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "         MEMOIRE RAM TOTALE"
    echo -e "==================================${RESET}"

    content="$(ssh_cmd "free -h | awk '/Mem:/ {print \$2}'")"
    echo "RAM totale : $content"
    save_info "$TARGET_NAME" "RAM totale : $content"
    log_action "RAMTotale_Ubuntu"

    pause
}

info_utilisation_ram() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "       UTILISATION DE LA RAM"
    echo -e "==================================${RESET}"

    content="$(ssh_cmd "free -h")"
    echo "$content"
    save_info "$TARGET_NAME" "$content"
    log_action "UtilisationRAM_Ubuntu"

    pause
}

info_updates() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "      MISES A JOUR MANQUANTES"
    echo -e "==================================${RESET}"

    content="$(ssh_cmd "apt list --upgradable 2>/dev/null")"
    echo "$content"
    save_info "$TARGET_NAME" "$content"
    log_action "Updates_Ubuntu"

    pause
}

# ==========================================
# ACTIONS ORDINATEUR
# ==========================================

redemarrer_machine() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "       REDEMARRAGE MACHINE"
    echo -e "==================================${RESET}"
    read -p "Confirmer le redémarrage ? (o/n) : " reponse

    if [ "$reponse" != "o" ]; then
        echo -e "${YELLOW}Redémarrage annulé${RESET}"
        log_action "RedemarrageAnnule_Ubuntu"
        pause
        return
    fi

    log_action "Redemarrage_Ubuntu"
    ssh_cmd "sudo reboot"
}

creer_repertoire() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "       CREATION REPERTOIRE"
    echo -e "==================================${RESET}"
    read -p "Chemin du répertoire à créer : " dir_path

    if [ -z "$dir_path" ]; then
        echo -e "${RED}Chemin invalide${RESET}"
        pause
        return
    fi

    ssh_cmd "mkdir -p '$dir_path'"
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}Répertoire créé sur Ubuntu${RESET}"
        log_action "CreateDir_Ubuntu"
    else
        echo -e "${RED}Erreur création répertoire sur Ubuntu${RESET}"
    fi

    pause
}

supprimer_repertoire() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "      SUPPRESSION REPERTOIRE"
    echo -e "==================================${RESET}"
    read -p "Chemin du répertoire à supprimer : " dir_path

    if [ -z "$dir_path" ]; then
        echo -e "${RED}Chemin invalide${RESET}"
        pause
        return
    fi

    ssh_cmd "rm -rf '$dir_path'"
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}Répertoire supprimé sur Ubuntu${RESET}"
        log_action "DeleteDir_Ubuntu"
    else
        echo -e "${RED}Erreur suppression répertoire sur Ubuntu${RESET}"
    fi

    pause
}

activer_parefeu() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "       ACTIVATION PARE-FEU"
    echo -e "==================================${RESET}"

    ssh_cmd "sudo ufw --force enable"
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}Pare-feu activé sur Ubuntu${RESET}"
        log_action "Parefeu_Ubuntu"
    else
        echo -e "${RED}Erreur activation pare-feu sur Ubuntu${RESET}"
    fi

    pause
}

# ==========================================
# ACTIONS UTILISATEUR
# ==========================================

lister_utilisateurs() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "      LISTE DES UTILISATEURS"
    echo -e "==================================${RESET}"

    content="$(ssh_cmd "cut -d: -f1 /etc/passwd")"
    echo "$content"
    save_info "$TARGET_NAME" "$content"
    log_action "ListeUsers_Ubuntu"

    pause
}

creer_utilisateur() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "       CREATION UTILISATEUR"
    echo -e "==================================${RESET}"
    read -p "Nom du nouvel utilisateur : " new_user

    if [ -z "$new_user" ]; then
        echo -e "${RED}Nom invalide${RESET}"
        pause
        return
    fi

    ssh_cmd "sudo useradd '$new_user'"
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}Utilisateur $new_user créé sur Ubuntu${RESET}"
        log_action "CreateUser_${new_user}_Ubuntu"
    else
        echo -e "${RED}Erreur création $new_user sur Ubuntu${RESET}"
    fi

    pause
}

supprimer_utilisateur() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "      SUPPRESSION UTILISATEUR"
    echo -e "==================================${RESET}"
    read -p "Nom de l'utilisateur à supprimer : " del_user

    if [ -z "$del_user" ]; then
        echo -e "${RED}Nom invalide${RESET}"
        pause
        return
    fi

    ssh_cmd "sudo userdel '$del_user'"
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}Utilisateur $del_user supprimé sur Ubuntu${RESET}"
        log_action "DeleteUser_${del_user}_Ubuntu"
    else
        echo -e "${RED}Erreur suppression $del_user sur Ubuntu${RESET}"
    fi

    pause
}

desactiver_utilisateur() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "     DESACTIVATION UTILISATEUR"
    echo -e "==================================${RESET}"
    read -p "Nom de l'utilisateur à désactiver : " target_user

    if [ -z "$target_user" ]; then
        echo -e "${RED}Nom invalide${RESET}"
        pause
        return
    fi

    ssh_cmd "sudo usermod -L '$target_user'"
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}Compte $target_user désactivé sur Ubuntu${RESET}"
        log_action "DisableUser_${target_user}_Ubuntu"
    else
        echo -e "${RED}Erreur désactivation sur Ubuntu${RESET}"
    fi

    pause
}

ajouter_groupe() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "         AJOUT A UN GROUPE"
    echo -e "==================================${RESET}"
    read -p "Nom de l'utilisateur : " target_user
    read -p "Nom du groupe : " group_name

    if [ -z "$target_user" ] || [ -z "$group_name" ]; then
        echo -e "${RED}Valeur invalide${RESET}"
        pause
        return
    fi

    ssh_cmd "sudo usermod -aG '$group_name' '$target_user'"
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}$target_user ajouté au groupe $group_name sur Ubuntu${RESET}"
        log_action "AddGroup_${target_user}_${group_name}_Ubuntu"
    else
        echo -e "${RED}Erreur ajout groupe sur Ubuntu${RESET}"
    fi

    pause
}

ajouter_groupe_admin() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "      AJOUT GROUPE ADMIN"
    echo -e "==================================${RESET}"
    read -p "Nom de l'utilisateur : " target_user

    if [ -z "$target_user" ]; then
        echo -e "${RED}Nom invalide${RESET}"
        pause
        return
    fi

    ssh_cmd "sudo usermod -aG sudo '$target_user'"
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}$target_user ajouté au groupe sudo sur Ubuntu${RESET}"
        log_action "AddAdmin_${target_user}_Ubuntu"
    else
        echo -e "${RED}Erreur ajout admin sur Ubuntu${RESET}"
    fi

    pause
}

changer_mot_de_passe() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "      MODIFICATION MOT DE PASSE"
    echo -e "==================================${RESET}"
    echo -e "${YELLOW}Règles du mot de passe :${RESET}"
    echo "- Minimum 8 caractères"
    echo "- Ne doit pas contenir le nom d'utilisateur"
    echo "- Utiliser majuscules, chiffres et caractères spéciaux"
    echo ""

    read -p "Nom de l'utilisateur : " target_user
    read -s -p "Nouveau mot de passe : " new_pass
    echo

    if [ -z "$target_user" ] || [ -z "$new_pass" ]; then
        echo -e "${RED}Valeur invalide${RESET}"
        pause
        return
    fi

    if [ ${#new_pass} -lt 8 ]; then
        echo -e "${RED}Mot de passe trop court${RESET}"
        pause
        return
    fi

    echo "$new_pass" | grep -i "$target_user" > /dev/null
    if [ $? -eq 0 ]; then
        echo -e "${RED}Le mot de passe ne doit pas contenir le nom d'utilisateur${RESET}"
        pause
        return
    fi

    ssh_cmd "echo '$target_user:$new_pass' | sudo chpasswd"
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}Mot de passe modifié pour $target_user sur Ubuntu${RESET}"
        log_action "ChangePassword_${target_user}_Ubuntu"
    else
        echo -e "${RED}Erreur modification mot de passe sur Ubuntu${RESET}"
    fi

    pause
}

# ==========================================
# INFORMATIONS UTILISATEUR
# ==========================================

info_groupes_utilisateur() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "     GROUPES D'APPARTENANCE"
    echo -e "==================================${RESET}"
    read -p "Nom de l'utilisateur : " target_user

    if [ -z "$target_user" ]; then
        echo -e "${RED}Nom invalide${RESET}"
        pause
        return
    fi

    content="$(ssh_cmd "groups '$target_user' 2>/dev/null")"
    echo "$content"
    save_info "$target_user" "$content"
    log_action "InfoGroupesUser_${target_user}_Ubuntu"
    pause
}

info_permissions_fichier() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "      PERMISSIONS FICHIER"
    echo -e "==================================${RESET}"
    read -p "Nom de l'utilisateur : " target_user
    read -p "Chemin du fichier : " file_path

    if [ -z "$target_user" ] || [ -z "$file_path" ]; then
        echo -e "${RED}Valeur invalide${RESET}"
        pause
        return
    fi

    content="$(ssh_cmd "ls -l '$file_path' 2>/dev/null")"
    echo "$content"
    save_info "$target_user" "$content"
    log_action "InfoPermissions_${target_user}_Ubuntu"
    pause
}

# ==========================================
# RECHERCHE DANS LES LOGS
# ==========================================

recherche_log_utilisateur() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "   RECHERCHE LOG UTILISATEUR"
    echo -e "==================================${RESET}"
    read -p "Nom de l'utilisateur à rechercher : " target_user

    if [ -z "$target_user" ]; then
        echo -e "${RED}Nom invalide${RESET}"
        pause
        return
    fi

    grep -i "$target_user" "$LOG_FILE"
    pause
}

recherche_log_machine() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "    RECHERCHE LOG MACHINE"
    echo -e "==================================${RESET}"
    read -p "Nom de la machine à rechercher : " target_machine

    if [ -z "$target_machine" ]; then
        echo -e "${RED}Nom invalide${RESET}"
        pause
        return
    fi

    grep -i "$target_machine" "$LOG_FILE"
    pause
}

menu_logs() {
    while true
    do
        clear
        echo -e "${CYAN}=================================="
        echo -e "       RECHERCHE DANS LES LOGS"
        echo -e "==================================${RESET}"
        echo "1 - Recherche par utilisateur"
        echo "2 - Recherche par machine"
        echo "3 - Retour"
        echo -e "${CYAN}==================================${RESET}"
        read -p "Votre choix : " choix

        case "$choix" in
            1) recherche_log_utilisateur ;;
            2) recherche_log_machine ;;
            3) break ;;
            *) echo -e "${RED}Choix invalide${RESET}"; pause ;;
        esac
    done
}

# ==========================================
# MENUS UBUNTU
# ==========================================

menu_actions_ordinateur() {
    while true
    do
        clear
        echo -e "${CYAN}=================================="
        echo -e "       ACTIONS ORDINATEUR"
        echo -e "==================================${RESET}"
        echo -e "${BLUE}Machine sélectionnée : Ubuntu${RESET}"
        echo "1 - Redémarrer la machine"
        echo "2 - Créer un répertoire"
        echo "3 - Supprimer un répertoire"
        echo "4 - Activer le pare-feu"
        echo "5 - Retour"
        echo -e "${CYAN}==================================${RESET}"
        read -p "Votre choix : " choix

        case "$choix" in
            1) redemarrer_machine ;;
            2) creer_repertoire ;;
            3) supprimer_repertoire ;;
            4) activer_parefeu ;;
            5) break ;;
            *) echo -e "${RED}Choix invalide${RESET}"; pause ;;
        esac
    done
}

menu_infos_ordinateur() {
    while true
    do
        clear
        echo -e "${CYAN}=================================="
        echo -e "      INFORMATIONS ORDINATEUR"
        echo -e "==================================${RESET}"
        echo -e "${BLUE}Machine sélectionnée : Ubuntu${RESET}"
        echo "1  - Informations système"
        echo "2  - Ports ouverts"
        echo "3  - Configuration réseau"
        echo "4  - Liste des interfaces"
        echo "5  - Version de l'OS"
        echo "6  - Applications / paquets installés"
        echo "7  - Services en cours"
        echo "8  - Mémoire RAM totale"
        echo "9  - Utilisation de la RAM"
        echo "10 - Mises à jour manquantes"
        echo "11 - Retour"
        echo -e "${CYAN}==================================${RESET}"
        read -p "Votre choix : " choix

        case "$choix" in
            1) info_systeme ;;
            2) info_ports_ouverts ;;
            3) info_reseau ;;
            4) info_interfaces ;;
            5) info_version_os ;;
            6) info_paquets ;;
            7) info_services ;;
            8) info_ram_totale ;;
            9) info_utilisation_ram ;;
            10) info_updates ;;
            11) break ;;
            *) echo -e "${RED}Choix invalide${RESET}"; pause ;;
        esac
    done
}

menu_actions_utilisateur() {
    while true
    do
        clear
        echo -e "${CYAN}=================================="
        echo -e "       ACTIONS UTILISATEUR"
        echo -e "==================================${RESET}"
        echo -e "${BLUE}Machine sélectionnée : Ubuntu${RESET}"
        echo "1 - Lister les utilisateurs"
        echo "2 - Créer un utilisateur"
        echo "3 - Supprimer un utilisateur"
        echo "4 - Désactiver un utilisateur"
        echo "5 - Ajouter à un groupe"
        echo "6 - Ajouter au groupe administration"
        echo "7 - Modifier le mot de passe"
        echo "8 - Retour"
        echo -e "${CYAN}==================================${RESET}"
        read -p "Votre choix : " choix

        case "$choix" in
            1) lister_utilisateurs ;;
            2) creer_utilisateur ;;
            3) supprimer_utilisateur ;;
            4) desactiver_utilisateur ;;
            5) ajouter_groupe ;;
            6) ajouter_groupe_admin ;;
            7) changer_mot_de_passe ;;
            8) break ;;
            *) echo -e "${RED}Choix invalide${RESET}"; pause ;;
        esac
    done
}

menu_infos_utilisateur() {
    while true
    do
        clear
        echo -e "${CYAN}=================================="
        echo -e "     INFORMATIONS UTILISATEUR"
        echo -e "==================================${RESET}"
        echo -e "${BLUE}Machine sélectionnée : Ubuntu${RESET}"
        echo "1 - Groupes d'appartenance"
        echo "2 - Droits / permissions sur un fichier"
        echo "3 - Retour"
        echo -e "${CYAN}==================================${RESET}"
        read -p "Votre choix : " choix

        case "$choix" in
            1) info_groupes_utilisateur ;;
            2) info_permissions_fichier ;;
            3) break ;;
            *) echo -e "${RED}Choix invalide${RESET}"; pause ;;
        esac
    done
}

menu_machine() {
    while true
    do
        clear
        echo -e "${CYAN}=================================="
        echo -e "        GESTION CLIENT UBUNTU"
        echo -e "==================================${RESET}"
        echo "1 - Actions ordinateur"
        echo "2 - Informations ordinateur"
        echo "3 - Actions utilisateur"
        echo "4 - Informations utilisateur"
        echo "5 - Retour"
        echo -e "${CYAN}==================================${RESET}"
        read -p "Votre choix : " choix

        case "$choix" in
            1) menu_actions_ordinateur ;;
            2) menu_infos_ordinateur ;;
            3) menu_actions_utilisateur ;;
            4) menu_infos_utilisateur ;;
            5) break ;;
            *) echo -e "${RED}Choix invalide${RESET}"; pause ;;
        esac
    done
}

# ==========================================
# DEMARRAGE SCRIPT
# ==========================================

log_action "StartScript"

while true
do
    clear
    echo -e "${CYAN}=================================="
    echo -e "          MENU PRINCIPAL"
    echo -e "==================================${RESET}"
    echo "1 - Choisir la machine Ubuntu"
    echo "2 - Consulter les logs"
    echo "3 - Quitter"
    echo -e "${CYAN}==================================${RESET}"
    read -p "Votre choix : " choix

    case "$choix" in
        1)
            echo -e "${GREEN}Machine sélectionnée : Ubuntu${RESET}"
            log_action "SelectMachine_Ubuntu"
            pause
            menu_machine
            ;;
        2)
            menu_logs
            ;;
        3)
            echo -e "${YELLOW}Arrêt du script${RESET}"
            log_action "EndScript"
            exit 0
            ;;
        *)
            echo -e "${RED}Choix invalide${RESET}"
            pause
            ;;
    esac
done
