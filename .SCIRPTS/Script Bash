system_info() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "      INFORMATIONS SYSTEME"
    echo -e "==================================${RESET}"

    local content=""

    if [ "$TARGET" = "debian" ]; then
        content="$(hostname; echo; grep PRETTY_NAME /etc/os-release; echo; free -h)"
        echo -e "${BLUE}Machine cible : Debian${RESET}"
        echo "$content"
        save_info "debian" "$content"
        log_action "InfoSystem_Debian"

    elif [ "$TARGET" = "ubuntu" ]; then
        content="$(ssh "$UBUNTU_ALIAS" "hostname; echo; grep PRETTY_NAME /etc/os-release; echo; free -h")"
        echo -e "${BLUE}Machine cible : Ubuntu${RESET}"
        echo "$content"
        save_info "ubuntu" "$content"
        log_action "InfoSystem_Ubuntu"

    else
        echo -e "${RED}Aucune machine sélectionnée${RESET}"
        log_action "Error_NoTarget"
    fi

    pause
