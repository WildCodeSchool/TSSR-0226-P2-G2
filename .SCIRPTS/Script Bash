reboot_machine() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "       REDEMARRAGE MACHINE"
    echo -e "==================================${RESET}"
    read -p "Confirmer le redémarrage ? (o/n) : " confirm

    if [ "$confirm" != "o" ]; then
        echo -e "${YELLOW}Redémarrage annulé${RESET}"
        log_action "RebootCancelled_${TARGET}"
        pause
        return
    fi

    if [ "$TARGET" = "debian" ]; then
        log_action "Reboot_Debian"
        sudo reboot
    elif [ "$TARGET" = "ubuntu" ]; then
        log_action "Reboot_Ubuntu"
        ssh "$UBUNTU_ALIAS" "sudo reboot"
    else
        echo -e "${RED}Aucune machine sélectionnée${RESET}"
        pause
    fi
}

create_directory() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "       CREATION REPERTOIRE"
    echo -e "==================================${RESET}"
    read -p "Chemin du répertoire à créer : " dir_path

    if [ -z "$dir_path" ]; then
        echo -e "${RED}Chemin invalide${RESET}"
        pause
        return
    fi

    if [ "$TARGET" = "debian" ]; then
        mkdir -p "$dir_path"
        if [ $? -eq 0 ]; then
            echo -e "${GREEN}Répertoire créé sur Debian${RESET}"
            log_action "CreateDirectory_Debian"
        else
            echo -e "${RED}Erreur création répertoire sur Debian${RESET}"
        fi
    elif [ "$TARGET" = "ubuntu" ]; then
        ssh "$UBUNTU_ALIAS" "mkdir -p '$dir_path'"
        if [ $? -eq 0 ]; then
            echo -e "${GREEN}Répertoire créé sur Ubuntu${RESET}"
            log_action "CreateDirectory_Ubuntu"
        else
            echo -e "${RED}Erreur création répertoire sur Ubuntu${RESET}"
        fi
    fi

    pause
}

delete_directory() {
    clear
    echo -e "${CYAN}=================================="
    echo -e "      SUPPRESSION REPERTOIRE"
    echo -e "==================================${RESET}"
