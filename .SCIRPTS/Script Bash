#!/bin/bash

# ==========================================
# Script administration Linux
# Machine : SRVLX01 (Debian)
# Cible distante : Ubuntu
# ==========================================

# VARIABLES GLOBALES
REMOTE_USER="wilder"
UBUNTU_ALIAS="ubuntu"
CURRENT_USER="$(whoami)"
INFO_DIR="info"
LOG_FILE="./log_evt.log"
TARGET=""

# COULEURS
RED="\e[91m"
GREEN="\e[92m"
YELLOW="\e[93m"
BLUE="\e[94m"
CYAN="\e[96m"
RESET="\e[0m"

# ==========================================
# FONCTIONS GENERALES
# ==========================================

log_action() {
    local event="$1"
    local date_part
    local time_part

    date_part="$(date '+%Y%m%d')"
    time_part="$(date '+%H%M%S')"

    echo "${date_part}_${time_part}_${CURRENT_USER}_${event}" >> "$LOG_FILE"
}

init_script() {
    mkdir -p "$INFO_DIR"
    touch "$LOG_FILE"
    log_action "StartScript"
}

end_script() {
    log_action "EndScript"
}

pause() {
    read -p "Appuyez sur Entrée pour continuer..."
}

save_info() {
    local target_name="$1"
    local content="$2"
    local today
    local file_path

    today="$(date '+%Y%m%d')"
    file_path="${INFO_DIR}/info_${target_name}_${today}.txt"

    echo "$content" > "$file_path"
    echo -e "${GREEN}Informations enregistrées dans : ${file_path}${RESET}"
    log_action "SaveInfo_${target_name}"
}

